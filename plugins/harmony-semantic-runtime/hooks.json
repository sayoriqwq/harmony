{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "name": "harmony-semantic-runtime-user-prompt",
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/user-prompt-submit.mjs",
            "statusMessage": "Checking semantic runtime...",
            "timeout": 12
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "apply_patch|mcp__semantic_runtime__.*",
        "hooks": [
          {
            "name": "harmony-semantic-runtime-action-gate",
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/pre-tool-use.mjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
