{
  "name": "harmony",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "effect:patch": "effect-tsgo patch",
    "effect:setup": "effect-tsgo setup",
    "effect:status": "node \"/Users/sayori/Desktop/yume-infra/effect-harness/dist/bin/effect-harness.js\" status",
    "effect:verify": "node \"/Users/sayori/Desktop/yume-infra/effect-harness/dist/bin/effect-harness.js\" verify --target .",
    "knip": "knip",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm test && pnpm lint && pnpm knip && pnpm effect:verify"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@effect/language-service": "catalog:",
    "@effect/tsgo": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "knip": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
